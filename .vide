{
    "build_system": "vweb js",
    "compiler": "g++",
    "compile_args": [],
    "source_files": [
        "web/start.js"
    ],
    "ip": "127.0.0.1",
    "port": "8000",
    "executable_args": [],
    "excluded_path_patterns": [
        "*.DS_Store",
        "*.git",
        "*.xcodeproj",
        "*node_modules",
        "bin"
    ],
    "excluded_code_scanning_path_patterns": [
        "dev/*",
        "api/client/browser*.js",
        "web/frontend/*"
    ],
    "excluded_code_scanning_rules": [
        "no-undef",
        "no-unused-vars",
        "no-mixed-spaces-and-tabs",
        "no-unreachable",
        "no-fallthrough",
        "no-constant-condition",
        "no-async-promise-executor",
        "no-empty"
    ],
    "ssh_remotes": [],
    "git_username": "libris",
    "git_email": "admin@libris.io",
    "git_remotes": [
        {"remote": "origin", "branch": "main", "destination": "git@github.com:librisio/.github.git", "enabled": true}
    ]
}